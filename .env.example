# Supabase PostgreSQL (Session pooler)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# App
SECRET_KEY=your-secret-key-here

# Frontend
NEXT_PUBLIC_API_URL=https://your-app.vercel.app/api

# CORS (comma-separated)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Obsidian Vault
OBSIDIAN_VAULT_PATH=/path/to/obsidian-vault

# Mercury API (HOI)
MERCURY_API_TOKEN=

# QuickBooks (HOI - Phase 2+)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REALM_ID=

# Codef.io (한국 법인 - Phase 2+)
# CODEF_ENV: "demo" (default, development.codef.io) | "production" (api.codef.io)
# CODEF_PUBLIC_KEY: Codef 포털 → 개발정보 관리 → 공개키 (PEM 또는 raw base64)
#   비밀번호 RSA(PKCS1v15) 암호화에 사용. 미설정 시 connect 요청 거절.
CODEF_CLIENT_ID=
CODEF_CLIENT_SECRET=
CODEF_ENV=demo
CODEF_PUBLIC_KEY=

# 수출입은행 환율 API
KOREAEXIM_API_KEY=
